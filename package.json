{
    "name": "radix-angular",
    "version": "0.0.0",
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/radix-ng/primitives.git"
    },
    "scripts": {
        "----Storybook----": "-----------------------------------------------------------------------",
        "storybook:primitives": "nx run radix-storybook:storybook",
        "build-storybook": "nx run radix-storybook:build-storybook",
        "static-storybook": "nx run radix-storybook:static-storybook",
        "----Visual Regression----": "------------------------------------------------------------",
        "test-visual": "nx run radix-storybook:build-storybook && playwright test -c apps/visual-regression/playwright.config.ts",
        "test-visual:update": "nx run radix-storybook:build-storybook && playwright test -c apps/visual-regression/playwright.config.ts --update-snapshots",
        "test-visual:report": "playwright show-report apps/visual-regression/playwright-report",
        "----Radix Primitives---": "-----------------------------------------------------------------",
        "primitives:build": "nx run primitives:build",
        "primitives:build:schematics": "nx run primitives:build:schematics",
        "primitives:test": "nx run primitives:test",
        "primitives:bench": "nx run radix-perf-testing:bench",
        "primitives:ssr:serve": "nx serve radix-ssr-testing",
        "primitives:ssr:build": "nx build radix-ssr-testing",
        "primitives:ssr:dist": "node dist/apps/radix-ssr-testing/server/server.mjs",
        "primitives:build:typedoc": "node tools/scripts/api-doc/build.mjs",
        "skills:build": "node tools/scripts/skills/generate.mjs",
        "----Playground---": "-----------------------------------------------------------------------",
        "playground": "nx serve radix-playground",
        "playground:docs-index": "node tools/scripts/playground/generate-mascot-docs.mjs",
        "playground:build": "nx build radix-playground",
        "build-site": "CI=1 NX_DAEMON=false nx build radix-playground && CI=1 NX_DAEMON=false nx run radix-storybook:build-storybook && node tools/scripts/build-site.mjs",
        "----Others-------": "-----------------------------------------------------------------------",
        "clean:node-modules": "rimraf ./apps/**/node_modules && rimraf ./packages/**/**/node_modules && rimraf ./node_modules",
        "prepare": "husky",
        "prettier": "prettier --check . --ignore-unknown",
        "prettier:fix": "pnpm run prettier --write",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "pnpm run stylelint --fix",
        "eslint": "eslint .",
        "eslint:fix": "pnpm run eslint --fix",
        "----NX-------": "-----------------------------------------------------------------------",
        "format": "nx format --base head~1",
        "migrate": "nx migrate latest",
        "run-migrate": "nx migrate --run-migrations --if-exists",
        "help": "nx help",
        "release:dry-run": "nx release --dry-run -- --skip-nx-cache",
        "----RELEASE Scripts-------": "---------------------------------------------------------",
        "release:skip-publish": "nx release --skip-publish",
        "release:primitives": "nx release --projects=primitives --skip-publish"
    },
