    {
      "name": "Menu",
      "slug": "menu",
      "section": "components",
      "description": "A headless dropdown menu anchored to a trigger button.",
      "doc": "radix-ng-examples/references/components/menu.md",
      "storybook": "https://radix-ng.com/?path=/docs/primitives-menu--docs",
      "anatomy": "<ng-container #root=\"rdxMenuRoot\" rdxMenuRoot>\n    <button rdxMenuTrigger>Open</button>\n\n    <ng-template rdxMenuPortal>\n        <!-- optional backdrop — a sibling root, before the positioner -->\n        <div rdxMenuBackdrop></div>\n\n        <div sideOffset=\"4\" rdxMenuPositioner>\n            <div rdxMenuPopup>\n                <span rdxMenuArrow></span>\n\n                <!-- regular item -->\n                <button rdxMenuItem>New Tab</button>\n\n                <!-- link item — does not close by default -->\n                <a rdxMenuLinkItem href=\"/settings\">Settings</a>\n\n                <div rdxMenuSeparator></div>\n\n                <!-- checkbox item — does not close the menu -->\n                <label rdxMenuCheckboxItem>\n                    <span rdxMenuCheckboxItemIndicator></span>\n                    Show Bookmarks\n                </label>\n\n                <!-- radio group — items do not close the menu by default -->\n                <div rdxMenuRadioGroup>\n                    <label value=\"grid\" rdxMenuRadioItem>\n                        <span rdxMenuRadioItemIndicator></span>\n                        Grid View\n                    </label>\n                    <label value=\"list\" rdxMenuRadioItem>\n                        <span rdxMenuRadioItemIndicator></span>\n                        List View\n                    </label>\n                </div>\n\n                <div rdxMenuSeparator></div>\n\n                <!-- group with a label -->\n                <div rdxMenuGroup>\n                    <span rdxMenuGroupLabel>Section</span>\n                    <button rdxMenuItem>Item</button>\n                </div>\n\n                <div rdxMenuSeparator></div>\n\n                <!-- submenu: wrap trigger + popup in a nested rdxMenuRoot -->\n                <ng-container #sub=\"rdxMenuRoot\" rdxMenuRoot>\n                    <button rdxMenuSubTrigger>More options ›</button>\n\n                    <div *rdxMenuPortal side=\"right\" align=\"start\" sideOffset=\"4\" rdxMenuPositioner>\n                        <div rdxMenuPopup>\n                            <button rdxMenuItem>Sub item A</button>\n                            <button rdxMenuItem>Sub item B</button>\n                        </div>\n                    </div>\n                </ng-container>\n            </div>\n        </div>\n    </ng-template>\n</ng-container>",
      "dataAttributes": []
    },
    {
      "name": "Menubar",
      "slug": "menubar",
      "section": "components",
      "description": "A visually persistent menu common in desktop applications that provides quick access to a consistent set of commands.",
      "doc": "radix-ng-examples/references/components/menubar.md",
      "storybook": "https://radix-ng.com/?path=/docs/primitives-menubar--docs",
      "anatomy": "<div rdxMenubarRoot>\n  <!-- File -->\n  <ng-container #fileMenu=\"rdxMenuRoot\" rdxMenuRoot>\n    <button rdxMenuTrigger>File</button>\n\n    <div class=\"data-[closed]:hidden\" align=\"start\" sideOffset=\"4\" rdxMenuPositioner>\n      <div rdxMenuPopup>\n        <button rdxMenuItem>New Tab</button>\n        <div rdxMenuSeparator></div>\n\n        <!-- submenu -->\n        <ng-container #shareSub=\"rdxMenuRoot\" rdxMenuRoot>\n          <button rdxMenuSubTrigger>Share ›</button>\n          @if (shareSub.open()) {\n          <div side=\"right\" align=\"start\" rdxMenuPositioner>\n            <div rdxMenuPopup>\n              <button rdxMenuItem>Email Link</button>\n            </div>\n          </div>\n          }\n        </ng-container>\n\n        <button rdxMenuItem>Print…</button>\n      </div>\n    </div>\n  </ng-container>\n\n  <!-- Edit -->\n  <ng-container #editMenu=\"rdxMenuRoot\" rdxMenuRoot>\n    <button rdxMenuTrigger>Edit</button>\n\n    <div class=\"data-[closed]:hidden\" align=\"start\" sideOffset=\"4\" rdxMenuPositioner>\n      <div rdxMenuPopup>\n        <button rdxMenuItem>Undo</button>\n        <button rdxMenuItem>Redo</button>\n      </div>\n    </div>\n  </ng-container>\n</div>",
      "dataAttributes": []
    },
