{
  "version": "1.1.1",
  "slug": "label",
  "section": "components",
  "parts": [
    {
      "directive": "RdxLabelDirective",
      "selector": "label[rdxLabel]",
      "exportAs": "rdxLabel",
      "inputs": [
        {
          "name": "htmlFor",
          "type": "string",
          "description": "The id of the element the label is associated with."
        },
        {
          "name": "id",
          "type": "string",
          "default": "injectId('rdx-label-')",
          "description": "The label id. Defaults to a stable generated id."
        }
      ],
      "outputs": []
    }
  ]
}
