{
    "redirects": [
        {
            "source": "/docs",
            "destination": "/docs/",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/playground",
            "destination": "/index.html"
        },
        {
            "source": "/playground/:path*",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
            "source": "/docs/assets/(.*)",
            "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
            "source": "/(.*).html",
            "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
        },
        {
            "source": "/docs/index.json",
            "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
        },
        {
            "source": "/",
            "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
        },
        {
            "source": "/docs/",
            "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
        }
    ]
}
